# --- Database ---
# Matches docker-compose.yml defaults; change for non-local environments.
DATABASE_URL="postgresql://ascend:ascend_dev_password@localhost:5432/ascend_hub?schema=public"

# --- Server ---
PORT=4000
# Secret used to sign session cookies. Generate a long random string for real deployments.
SESSION_SECRET="change-me-to-a-long-random-string"
# Origin of the client app (used for links in emails)
APP_URL="http://localhost:5173"
NODE_ENV=development

# --- Email (SMTP) fallbacks ---
# Settings saved in the app (Settings page) take precedence over these.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ascend Hub <noreply@unifyconsulting.com>"

# --- Microsoft Teams ---
# Incoming webhook URL for the briefing broadcast channel (can also be set in Settings).
TEAMS_WEBHOOK_URL=""

# --- Scheduler ---
# IANA timezone the scheduler evaluates ping/briefing times in.
SCHEDULER_TIMEZONE="America/Los_Angeles"
