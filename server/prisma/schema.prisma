generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  member
}

enum TaskStatus {
  not_started
  in_progress
  blocked
  closed // single terminal state — a task is "done"/wrapped up (renamed from the old `complete`)
  paused // deliberately parked (e.g. awaiting the next meeting); distinct from blocked (stuck on something external)
}

enum Priority {
  high
  medium
  low
}

// Self-reported weekly client-engagement level. Maps (via configurable settings)
// to a baseline of client hours: low=30, medium=40, high=50 by default. It is an
// ADVISORY signal only — the Capacity page uses it to show "who has room" against
// a soft 40h reference line; nothing is ever blocked or capped on this value.
enum CapacityLevel {
  low
  medium
  high
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(member)
  isActive     Boolean  @default(true)
  pingTime     String? // "HH:mm" 24h, user's preferred daily ping time; null = team default
  createdAt    DateTime @default(now())

  createdTasks    Task[]           @relation("TaskCreator")
  assignments     TaskAssignment[]
  checkIns        CheckIn[]
  // One self-reported client-engagement rating per (user, week). Drives the
  // advisory Capacity page; see WeeklyCapacity below.
  weeklyCapacities WeeklyCapacity[]
  // Personal briefings this user has generated (or had auto-generated). Each is owned
  // by and visible only to this user; see WeeklyBriefing.
  briefings        WeeklyBriefing[]
}

model Task {
  id               String     @id @default(cuid())
  title            String
  description      String?
  requestedBy      String // leader name, free text
  submittedAt      DateTime   @default(now())
  status           TaskStatus @default(not_started)
  priority         Priority   @default(medium)
  isWip            Boolean    @default(false)
  // Timestamp the task became terminal (status = closed). Set when it transitions
  // into `closed`, cleared back to null if it is reopened. Drives the Closed board
  // column (current-quarter window) and the Closed-tasks reporting view.
  closedAt         DateTime?
  estimatedDueDate DateTime? // null when isWip is true or timeline unknown
  targetStartDate  DateTime?
  estimatedHours   Float?
  bucket           String
  initiative       String? // optional
  // Salesforce opportunity link or 15/18-char ID. Optional and primarily for
  // proposals: lets the (external) influenced-revenue dashboard join a proposal
  // to its dollar amount by opportunity instead of fuzzy title/leader matching.
  // The person entering a task often lacks Salesforce access, so it's nullable
  // and filled in later by whoever does (an Ascender w/ access or solution/delivery).
  salesforceOpportunity String?
  createdById      String
  createdBy        User       @relation("TaskCreator", fields: [createdById], references: [id])
  // Parent/child (subtask) link, one level deep. A subtask is a normal Task whose
  // parentId points at its parent; the parent's own parentId must stay null (we
  // reject nesting beyond one level in the POST route). Cascade delete means
  // removing a parent also removes its subtasks, matching the board/detail UX
  // where subtasks have no independent existence away from their parent.
  parentId         String?
  parent           Task?      @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks         Task[]     @relation("Subtasks")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignments TaskAssignment[]
  checkIns    CheckIn[]

  @@index([status])
  @@index([bucket])
  @@index([parentId])
}

model TaskAssignment {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  startDate   DateTime?
  endDate     DateTime? // null = still active
  hoursLogged Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([taskId, userId])
  @@index([userId])
}

// A personal briefing. Each row belongs to one user (its owner) and summarizes only
// that person's logged hours and tasks over [weekStart, weekEnd]; users only ever see
// their own. weekStart/weekEnd are generic range bounds — a briefing can span any
// window, not just a calendar week. Delivery flags were dropped: briefings are read
// in-app only, never emailed or posted. Cascade-deletes with the owning user.
model WeeklyBriefing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  weekEnd     DateTime
  content     String // markdown
  generatedAt DateTime @default(now())

  @@index([userId])
}

model CheckIn {
  id           String    @id @default(cuid())
  taskId       String
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  sentAt       DateTime  @default(now())
  channel      String    @default("email")
  responseText String?
  respondedAt  DateTime?

  @@index([userId, sentAt])
}

// A single person's self-reported client-engagement level for one week. We store
// one row per (userId, weekStart) and upsert on that pair so re-rating a week
// overwrites rather than duplicates. weekStart is always the Monday of the week at
// UTC midnight, giving a stable, timezone-independent key to group/filter by.
model WeeklyCapacity {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  weekStart DateTime // Monday 00:00 UTC of the rated week
  level     CapacityLevel
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // One rating per person per week — the POST endpoint upserts on this pair.
  @@unique([userId, weekStart])
  // The Capacity page always queries by a single week, so index weekStart.
  @@index([weekStart])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
